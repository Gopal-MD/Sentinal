# SENTINEL ENHANCED - ENVIRONMENT CONFIGURATION

# APP CORE
NODE_ENV=development
APP_NAME=SENTINEL_ENHANCED
PORT_FRONTEND=3000

# AUTHENTICATION (NextAuth v5)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# GOOGLE CLOUD PROJECT
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
VERTEX_AI_LOCATION=asia-south1
BIGQUERY_DATASET=sentinel_data
PUBSUB_PROJECT_ID=your-project-id

# API KEYS
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_WEATHER_API_KEY=AIza...

# FIREBASE CONFIG (WEB SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-app
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-app-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:12345:web:abcd
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ABCDE

# SERVICE PORTS (INTERNAL DOCKER)
PORT_WEATHER_SERVICE=8080
PORT_RISK_ENGINE=8081
PORT_INVENTORY_SERVICE=8082
PORT_WAREHOUSE_SERVICE=8083
PORT_VENDOR_SERVICE=8084

# SERVICE URLS (FOR CROSS-SERVICE COMM)
WEATHER_SERVICE_URL=http://weather-service:8080
RISK_ENGINE_URL=http://risk-engine:8080
INVENTORY_SERVICE_URL=http://inventory-service:8080
WAREHOUSE_SERVICE_URL=http://warehouse-service:8080
VENDOR_SERVICE_URL=http://vendor-service:8080

# SIMULATOR SETTINGS
SIMULATION_INTERVAL_MS=30000
DISRUPTION_CHANCE=0.05
